# Optional nvm version switch (.nvmrc). Fenced with set +e: husky runs hooks
# under `sh -e`, and nvm re-arms errexit internally before returning non-zero —
# without the fence a missing nvm version kills the hook before its real work.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    set +e
    . "$NVM_DIR/nvm.sh" > /dev/null 2>&1
    nvm use --silent > /dev/null 2>&1
    set -e
fi

echo "→ format:check"
npm run format:check || { echo "❌ Formatting check failed. Run 'npm run format' and re-commit."; exit 1; }

echo "→ lint"
npm run lint || { echo "❌ Lint failed. Fix errors before push."; exit 1; }

echo "→ type-check"
npx tsc -b --noEmit || { echo "❌ TypeScript type-check failed. Fix errors before push."; exit 1; }
