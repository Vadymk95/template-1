# Environment Variables Template
# Copy this file to .env and fill in your values.
# All VITE_* vars are validated by src/env.ts (Zod) at build time.

# API base URL (optional — remove if using Supabase / Firebase SDK that owns its own client).
# VITE_API_URL=https://api.example.com

# Web Vitals: true loads web-vitals/attribution (richer LCP/INP/CLS debug targets, ~1-2 KB extra).
# VITE_WEB_VITALS_ATTRIBUTION=false

# Dev-only browser MSW worker (mocks API responses). DEV gate is unconditional in main.tsx;
# this flag lets you turn the worker off entirely (e.g. when hitting a real local backend).
# Default: enabled in dev. Set to 'false' to disable.
# VITE_ENABLE_MSW=true
